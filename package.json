{
  "name": "thiscord",
  "version": "0.1.0",
  "description": "ThisCord — Modern Communication Platform",
  "author": "Elias <elias_1414@icloud.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build:win": "electron-builder --win --x64 --ia32 --arm64",
    "build:linux": "electron-builder --linux --x64 --arm64",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:all": "electron-builder --win --linux --mac --x64 --ia32 --arm64",
    "build:server": "pkg server.js --targets node18-win-x64 --output server-dist/ThisCord-Server.exe"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "server-dist",
    "scripts": [
      "server.js"
    ],
    "assets": []
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "electron-updater": "^6.3.0",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.thiscord.app",
    "productName": "ThisCord",
    "copyright": "© 2026 ThisCord Project",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "welias123",
      "repo": "thiscord-app"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signDlls": false,
      "sign": null,
      "certificateFile": null,
      "publisherName": "ThisCord Project",
      "legalTrademarks": "ThisCord",
      "executableName": "ThisCord",
      "fileAssociations": [],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.social-networking",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Install ThisCord",
      "iconSize": 80,
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ThisCord"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Network",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0",
    "pkg": "^5.8.1"
  }
}
